---
import { getCollection, render } from 'astro:content';
import ContentCard from '../../components/ContentCard.astro';
import DiagramPanel from '../../components/DiagramPanel.astro';
import PageIntro from '../../components/PageIntro.astro';
import Layout from '../../layouts/Layout.astro';
import { formatDate, getEntryHref, resolveBySlugs, sortByTitle } from '../../lib/content';

export async function getStaticPaths() {
	const conditions = await getCollection('conditions');
	return conditions.map((entry) => ({
		params: { slug: entry.data.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const [subjects, systems, topics, diagrams, drugs, investigations, procedures, sources, conditions] = await Promise.all([
	getCollection('subjects'),
	getCollection('systems'),
	getCollection('topics'),
	getCollection('diagrams'),
	getCollection('drugs'),
	getCollection('investigations'),
	getCollection('procedures'),
	getCollection('sources'),
	getCollection('conditions'),
]);

const relatedSubject = subjects.find((item) => item.data.slug === entry.data.primarySubject);
const relatedSystems = resolveBySlugs(systems, entry.data.systems);
const relatedTopics = resolveBySlugs(topics, entry.data.relatedTopics);
const relatedDiagrams = sortByTitle(diagrams.filter((item) => item.data.relatedConditions.includes(entry.data.slug)));
const relatedDrugs = sortByTitle(drugs.filter((item) => item.data.relatedConditions.includes(entry.data.slug)));
const relatedInvestigations = sortByTitle(investigations.filter((item) => item.data.relatedConditions.includes(entry.data.slug)));
const relatedProcedures = sortByTitle(procedures.filter((item) => item.data.relatedConditions.includes(entry.data.slug)));
const relatedSources = resolveBySlugs(sources, entry.data.sourceSlugs);
const relatedConditions = sortByTitle(
	conditions.filter(
		(item) =>
			item.data.slug !== entry.data.slug &&
			(item.data.primarySubject === entry.data.primarySubject ||
				item.data.systems.some((slug) => entry.data.systems.includes(slug))),
	).slice(0, 4),
);
---

<Layout title={`${entry.data.title} | Med Wiki`} description={entry.data.summary} pagefindIndexed={true}>
	<PageIntro
		eyebrow="Condition"
		title={entry.data.title}
		summary={entry.data.summary}
		meta={[
			relatedSubject?.data.title ?? 'Clinical subject',
			`${entry.data.maturity} page`,
			`Reviewed ${formatDate(entry.data.lastReviewed)}`,
		]}
		breadcrumbs={[
			{ label: 'Home', href: '/' },
			{ label: 'Conditions', href: '/conditions' },
			{ label: entry.data.title },
		]}
	/>

	<section class="page-grid">
		<article class="page-copy prose" data-pagefind-body>
			<section>
				<h2>Typical presentation</h2>
				<p>{entry.data.presentation}</p>
			</section>
			<section>
				<h2>Why this condition matters</h2>
				<p>{entry.data.whyItMatters}</p>
			</section>
			{relatedDiagrams.length > 0 && (
				<section>
					<h2>Visual guide</h2>
					<div class="diagram-stack">
						{relatedDiagrams.map((diagram) => <DiagramPanel diagram={diagram} />)}
					</div>
				</section>
			)}
			{entry.data.redFlags.length > 0 && (
				<section>
					<h2>Red flags</h2>
					<ul>
						{entry.data.redFlags.map((item) => <li>{item}</li>)}
					</ul>
				</section>
			)}
			{entry.data.workup.length > 0 && (
				<section>
					<h2>Initial workup</h2>
					<ul>
						{entry.data.workup.map((item) => <li>{item}</li>)}
					</ul>
				</section>
			)}
			{entry.data.firstLine.length > 0 && (
				<section>
					<h2>First-line management</h2>
					<ul>
						{entry.data.firstLine.map((item) => <li>{item}</li>)}
					</ul>
				</section>
			)}
			{entry.data.whenToRefer.length > 0 && (
				<section>
					<h2>When to refer or escalate</h2>
					<ul>
						{entry.data.whenToRefer.map((item) => <li>{item}</li>)}
					</ul>
				</section>
			)}
			<Content />
		</article>

		<aside class="page-sidebar">
			<div class="info-panel">
				<h3>Condition profile</h3>
				<ul class="detail-list">
					<li>Maturity: {entry.data.maturity}</li>
					<li>Last reviewed: {formatDate(entry.data.lastReviewed)}</li>
					<li>{entry.data.redFlags.length} red flag{entry.data.redFlags.length === 1 ? '' : 's'}</li>
					<li>{entry.data.workup.length} workup step{entry.data.workup.length === 1 ? '' : 's'}</li>
				</ul>
			</div>
			{relatedSystems.length > 0 && (
				<div class="info-panel">
					<h3>Linked systems</h3>
					<div class="link-list">
						{relatedSystems.map((system) => <a class="tag-chip" href={getEntryHref('systems', system.data.slug)}>{system.data.title}</a>)}
					</div>
				</div>
			)}
			{relatedSources.length > 0 && (
				<div class="info-panel">
					<h3>Source layer</h3>
					<ul class="detail-list">
						{
							relatedSources.map((source) => (
								<li>
									<a href={getEntryHref('sources', source.data.slug)}>{source.data.title}</a>
									{' · '}
									<span>{source.data.tier}</span>
								</li>
							))
						}
					</ul>
				</div>
			)}
			{relatedDrugs.length > 0 && (
				<div class="info-panel">
					<h3>Drug links</h3>
					<div class="link-list">
						{relatedDrugs.map((drug) => <a class="tag-chip" href={getEntryHref('drugs', drug.data.slug)}>{drug.data.title}</a>)}
					</div>
				</div>
			)}
			{relatedInvestigations.length > 0 && (
				<div class="info-panel">
					<h3>Investigations</h3>
					<div class="link-list">
						{relatedInvestigations.map((investigation) => <a class="tag-chip" href={getEntryHref('investigations', investigation.data.slug)}>{investigation.data.title}</a>)}
					</div>
				</div>
			)}
			{relatedProcedures.length > 0 && (
				<div class="info-panel">
					<h3>Procedures</h3>
					<div class="link-list">
						{relatedProcedures.map((procedure) => <a class="tag-chip" href={getEntryHref('procedures', procedure.data.slug)}>{procedure.data.title}</a>)}
					</div>
				</div>
			)}
		</aside>
	</section>

	<section class="section-split">
		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Foundations</p>
					<h2>Topics that explain the condition</h2>
				</div>
			</div>
			<div class="stack">
				{
					relatedTopics.length > 0 ? (
						relatedTopics.map((topic) => (
							<ContentCard
								eyebrow={topic.data.maturity}
								title={topic.data.title}
								description={topic.data.summary}
								href={getEntryHref('topics', topic.data.slug)}
								meta={`Reviewed ${formatDate(topic.data.lastReviewed)}`}
							/>
						))
					) : (
						<div class="search-empty">Foundational links will appear here as the condition graph expands.</div>
					)
				}
			</div>
		</div>

		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">More Conditions</p>
					<h2>Related clinical pages</h2>
				</div>
			</div>
			<div class="stack">
				{
					relatedConditions.length > 0 ? (
						relatedConditions.map((condition) => (
							<ContentCard
								eyebrow={condition.data.maturity}
								title={condition.data.title}
								description={condition.data.summary}
								href={getEntryHref('conditions', condition.data.slug)}
								meta={`Reviewed ${formatDate(condition.data.lastReviewed)}`}
							/>
						))
					) : (
						<div class="search-empty">More connected condition pages will appear here as the clinical layer grows.</div>
					)
				}
			</div>
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Drugs</p>
				<h2>Formulary pages linked to this condition</h2>
			</div>
		</div>
		<div class="card-grid">
			{
				relatedDrugs.length > 0 ? (
					relatedDrugs.map((drug) => (
						<ContentCard
							eyebrow={drug.data.maturity}
							title={drug.data.title}
							description={drug.data.summary}
							href={getEntryHref('drugs', drug.data.slug)}
							meta={`${drug.data.drugClass} · Reviewed ${formatDate(drug.data.lastReviewed)}`}
						/>
					))
				) : (
					<div class="search-empty">Drug links for this condition are still being expanded.</div>
				)
			}
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Investigations</p>
				<h2>Diagnostic pages linked to this condition</h2>
			</div>
		</div>
		<div class="card-grid">
			{
				relatedInvestigations.length > 0 ? (
					relatedInvestigations.map((investigation) => (
						<ContentCard
							eyebrow={investigation.data.maturity}
							title={investigation.data.title}
							description={investigation.data.summary}
							href={getEntryHref('investigations', investigation.data.slug)}
							meta={`${investigation.data.investigationType} · Reviewed ${formatDate(investigation.data.lastReviewed)}`}
						/>
					))
				) : (
					<div class="search-empty">Diagnostic links for this condition are still being expanded.</div>
				)
			}
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Procedures</p>
				<h2>Practical pages linked to this condition</h2>
			</div>
		</div>
		<div class="card-grid">
			{
				relatedProcedures.length > 0 ? (
					relatedProcedures.map((procedure) => (
						<ContentCard
							eyebrow={procedure.data.maturity}
							title={procedure.data.title}
							description={procedure.data.summary}
							href={getEntryHref('procedures', procedure.data.slug)}
							meta={`${procedure.data.procedureType} · Reviewed ${formatDate(procedure.data.lastReviewed)}`}
						/>
					))
				) : (
					<div class="search-empty">Practical links for this condition are still being expanded.</div>
				)
			}
		</div>
	</section>
</Layout>
