---
import { getCollection, render } from 'astro:content';
import ContentCard from '../../components/ContentCard.astro';
import DiagramPanel from '../../components/DiagramPanel.astro';
import PageIntro from '../../components/PageIntro.astro';
import Layout from '../../layouts/Layout.astro';
import { formatDate, getEntryHref, resolveBySlugs, sortByTitle, uniqueBySlug } from '../../lib/content';

export async function getStaticPaths() {
	const topics = await getCollection('topics');
	return topics.map((entry) => ({
		params: { slug: entry.data.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const [phases, subjects, systems, topics, conditions, diagrams, drugs, investigations, sources] = await Promise.all([
	getCollection('phases'),
	getCollection('subjects'),
	getCollection('systems'),
	getCollection('topics'),
	getCollection('conditions'),
	getCollection('diagrams'),
	getCollection('drugs'),
	getCollection('investigations'),
	getCollection('sources'),
]);

const relatedPhase = phases.find((item) => item.data.slug === entry.data.phase);
const relatedSubject = subjects.find((item) => item.data.slug === entry.data.subject);
const relatedSystems = resolveBySlugs(systems, entry.data.systems);
const relatedSources = resolveBySlugs(sources, entry.data.sourceSlugs);
const relatedDiagrams = resolveBySlugs(diagrams, entry.data.diagramSlugs);
const linkedDrugs = sortByTitle(drugs.filter((item) => item.data.relatedTopics.includes(entry.data.slug)));
const linkedInvestigations = sortByTitle(investigations.filter((item) => item.data.relatedTopics.includes(entry.data.slug)));
const linkedConditions = sortByTitle(conditions.filter((item) => item.data.relatedTopics.includes(entry.data.slug)));
const relatedTopics = sortByTitle(
	uniqueBySlug([
		...resolveBySlugs(topics, entry.data.relatedTopics),
		...topics.filter(
			(item) =>
				item.data.slug !== entry.data.slug &&
				(item.data.subject === entry.data.subject || item.data.systems.some((slug) => entry.data.systems.includes(slug))),
		),
	]).slice(0, 6),
);
---

<Layout title={`${entry.data.title} | Med Wiki`} description={entry.data.summary} pagefindIndexed={true}>
	<PageIntro
		eyebrow="Topic"
		title={entry.data.title}
		summary={entry.data.summary}
		meta={[
			relatedSubject?.data.title ?? 'Subject',
			relatedPhase?.data.title ?? 'MBBS',
			`${entry.data.maturity} page`,
			`Reviewed ${formatDate(entry.data.lastReviewed)}`,
		]}
		breadcrumbs={[
			{ label: 'Home', href: '/' },
			{ label: 'Topics', href: '/topics' },
			{ label: entry.data.title },
		]}
	/>

	<section class="page-grid">
		<article class="page-copy prose" data-pagefind-body>
			<section>
				<h2>Study goal</h2>
				<p>{entry.data.studyGoal}</p>
			</section>
			{relatedDiagrams.length > 0 && (
				<section>
					<h2>Visual map</h2>
					<div class="diagram-stack">
						{relatedDiagrams.map((diagram) => <DiagramPanel diagram={diagram} />)}
					</div>
				</section>
			)}
			<section>
				<h2>Clinical bridge</h2>
				<p>{entry.data.clinicalBridge}</p>
			</section>
			<Content />
		</article>

		<aside class="page-sidebar">
			<div class="info-panel">
				<h3>Review status</h3>
				<ul class="detail-list">
					<li>Maturity: {entry.data.maturity}</li>
					<li>Audience: {entry.data.audience}</li>
					<li>Last reviewed: {formatDate(entry.data.lastReviewed)}</li>
				</ul>
			</div>
			<div class="info-panel">
				<h3>High-yield points</h3>
				<ul class="detail-list">
					{entry.data.highYield.map((item) => <li>{item}</li>)}
				</ul>
			</div>
			{entry.data.examFocus.length > 0 && (
				<div class="info-panel">
					<h3>Exam focus</h3>
					<div class="link-list">
						{entry.data.examFocus.map((item) => <span class="tag-chip">{item}</span>)}
					</div>
				</div>
			)}
			{relatedSystems.length > 0 && (
				<div class="info-panel">
					<h3>Linked systems</h3>
					<div class="link-list">
						{relatedSystems.map((system) => <a class="tag-chip" href={getEntryHref('systems', system.data.slug)}>{system.data.title}</a>)}
					</div>
				</div>
			)}
			{linkedConditions.length > 0 && (
				<div class="info-panel">
					<h3>Clinical links</h3>
					<div class="link-list">
						{linkedConditions.map((condition) => <a class="tag-chip" href={getEntryHref('conditions', condition.data.slug)}>{condition.data.title}</a>)}
					</div>
				</div>
			)}
			{linkedDrugs.length > 0 && (
				<div class="info-panel">
					<h3>Drug links</h3>
					<div class="link-list">
						{linkedDrugs.map((drug) => <a class="tag-chip" href={getEntryHref('drugs', drug.data.slug)}>{drug.data.title}</a>)}
					</div>
				</div>
			)}
			{linkedInvestigations.length > 0 && (
				<div class="info-panel">
					<h3>Investigations</h3>
					<div class="link-list">
						{linkedInvestigations.map((investigation) => <a class="tag-chip" href={getEntryHref('investigations', investigation.data.slug)}>{investigation.data.title}</a>)}
					</div>
				</div>
			)}
			{relatedSources.length > 0 && (
				<div class="info-panel">
					<h3>Source layer</h3>
					<ul class="detail-list">
						{
							relatedSources.map((source) => (
								<li>
									<a href={getEntryHref('sources', source.data.slug)}>{source.data.title}</a>
									{' · '}
									<span>{source.data.tier}</span>
								</li>
							))
						}
					</ul>
				</div>
			)}
		</aside>
	</section>

	<section class="section-split">
		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Context</p>
					<h2>Where this topic lives in the course</h2>
				</div>
			</div>
			<div class="stack">
				{relatedSubject && (
					<ContentCard
						eyebrow="Subject"
						title={relatedSubject.data.title}
						description={relatedSubject.data.summary}
						href={getEntryHref('subjects', relatedSubject.data.slug)}
						meta={relatedPhase?.data.title}
					/>
				)}
				{relatedPhase && (
					<ContentCard
						eyebrow="Phase"
						title={relatedPhase.data.title}
						description={relatedPhase.data.summary}
						href={getEntryHref('phases', relatedPhase.data.slug)}
						meta={relatedPhase.data.duration}
					/>
				)}
			</div>
		</div>

		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Related Topics</p>
					<h2>What to study next</h2>
				</div>
			</div>
			<div class="stack">
				{
					relatedTopics.length > 0 ? (
						relatedTopics.map((topic) => (
						<ContentCard
							eyebrow={topic.data.maturity}
							title={topic.data.title}
							description={topic.data.summary}
							href={getEntryHref('topics', topic.data.slug)}
							meta={`Reviewed ${formatDate(topic.data.lastReviewed)}`}
						/>
					))
					) : (
						<div class="search-empty">More connected topics will appear here as the corpus grows.</div>
					)
				}
			</div>
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Conditions</p>
				<h2>Where this topic becomes clinically useful</h2>
			</div>
		</div>
		<div class="card-grid">
			{
				linkedConditions.length > 0 ? (
					linkedConditions.map((condition) => (
						<ContentCard
							eyebrow={condition.data.maturity}
							title={condition.data.title}
							description={condition.data.summary}
							href={getEntryHref('conditions', condition.data.slug)}
							meta={`Reviewed ${formatDate(condition.data.lastReviewed)}`}
						/>
					))
				) : (
					<div class="search-empty">Clinical condition links for this topic are still being expanded.</div>
				)
			}
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Drugs</p>
				<h2>Key formulary pages linked to this topic</h2>
			</div>
		</div>
		<div class="card-grid">
			{
				linkedDrugs.length > 0 ? (
					linkedDrugs.map((drug) => (
						<ContentCard
							eyebrow={drug.data.maturity}
							title={drug.data.title}
							description={drug.data.summary}
							href={getEntryHref('drugs', drug.data.slug)}
							meta={`${drug.data.drugClass} · Reviewed ${formatDate(drug.data.lastReviewed)}`}
						/>
					))
				) : (
					<div class="search-empty">Drug links for this topic are still being expanded.</div>
				)
			}
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Investigations</p>
				<h2>Diagnostic pages linked to this topic</h2>
			</div>
		</div>
		<div class="card-grid">
			{
				linkedInvestigations.length > 0 ? (
					linkedInvestigations.map((investigation) => (
						<ContentCard
							eyebrow={investigation.data.maturity}
							title={investigation.data.title}
							description={investigation.data.summary}
							href={getEntryHref('investigations', investigation.data.slug)}
							meta={`${investigation.data.investigationType} · Reviewed ${formatDate(investigation.data.lastReviewed)}`}
						/>
					))
				) : (
					<div class="search-empty">Diagnostic links for this topic are still being expanded.</div>
				)
			}
		</div>
	</section>
</Layout>
