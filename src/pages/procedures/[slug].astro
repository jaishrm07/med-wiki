---
import { getCollection, render } from 'astro:content';
import ContentCard from '../../components/ContentCard.astro';
import PageIntro from '../../components/PageIntro.astro';
import Layout from '../../layouts/Layout.astro';
import { formatDate, getEntryHref, resolveBySlugs, sortByTitle } from '../../lib/content';

export async function getStaticPaths() {
	const procedures = await getCollection('procedures');
	return procedures.map((entry) => ({
		params: { slug: entry.data.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const [subjects, systems, topics, conditions, presentations, investigations, sources, procedures] = await Promise.all([
	getCollection('subjects'),
	getCollection('systems'),
	getCollection('topics'),
	getCollection('conditions'),
	getCollection('presentations'),
	getCollection('investigations'),
	getCollection('sources'),
	getCollection('procedures'),
]);

const relatedSubject = subjects.find((item) => item.data.slug === entry.data.primarySubject);
const relatedSystems = resolveBySlugs(systems, entry.data.systems);
const relatedTopics = resolveBySlugs(topics, entry.data.relatedTopics);
const relatedConditions = resolveBySlugs(conditions, entry.data.relatedConditions);
const relatedPresentations = resolveBySlugs(presentations, entry.data.relatedPresentations);
const relatedInvestigations = resolveBySlugs(investigations, entry.data.relatedInvestigations);
const relatedSources = resolveBySlugs(sources, entry.data.sourceSlugs);
const relatedProcedures = sortByTitle(
	procedures.filter(
		(item) =>
			item.data.slug !== entry.data.slug &&
			(item.data.primarySubject === entry.data.primarySubject ||
				item.data.systems.some((slug) => entry.data.systems.includes(slug))),
	).slice(0, 4),
);
---

<Layout title={`${entry.data.title} | Med Wiki`} description={entry.data.summary} pagefindIndexed={true}>
	<PageIntro
		eyebrow="Procedure"
		title={entry.data.title}
		summary={entry.data.summary}
		meta={[
			relatedSubject?.data.title ?? 'Clinical subject',
			entry.data.procedureType,
			`Reviewed ${formatDate(entry.data.lastReviewed)}`,
		]}
		breadcrumbs={[
			{ label: 'Home', href: '/' },
			{ label: 'Procedures', href: '/procedures' },
			{ label: entry.data.title },
		]}
	/>

	<section class="page-grid">
		<article class="page-copy prose" data-pagefind-body>
			<section>
				<h2>Why this procedure matters</h2>
				<p>{entry.data.whyItMatters}</p>
			</section>
			{entry.data.indications.length > 0 && (
				<section>
					<h2>When to use it</h2>
					<ul>
						{entry.data.indications.map((item) => <li>{item}</li>)}
					</ul>
				</section>
			)}
			{entry.data.equipment.length > 0 && (
				<section>
					<h2>What you need</h2>
					<ul>
						{entry.data.equipment.map((item) => <li>{item}</li>)}
					</ul>
				</section>
			)}
			{entry.data.keySteps.length > 0 && (
				<section>
					<h2>Key steps</h2>
					<ul>
						{entry.data.keySteps.map((item) => <li>{item}</li>)}
					</ul>
				</section>
			)}
			{entry.data.pitfalls.length > 0 && (
				<section>
					<h2>Common pitfalls</h2>
					<ul>
						{entry.data.pitfalls.map((item) => <li>{item}</li>)}
					</ul>
				</section>
			)}
			<Content />
		</article>

		<aside class="page-sidebar">
			<div class="info-panel">
				<h3>Procedure profile</h3>
				<ul class="detail-list">
					<li>Type: {entry.data.procedureType}</li>
					<li>Maturity: {entry.data.maturity}</li>
					<li>Last reviewed: {formatDate(entry.data.lastReviewed)}</li>
					<li>{entry.data.keySteps.length} key step{entry.data.keySteps.length === 1 ? '' : 's'}</li>
				</ul>
			</div>
			{relatedSystems.length > 0 && (
				<div class="info-panel">
					<h3>Linked systems</h3>
					<div class="link-list">
						{relatedSystems.map((system) => <a class="tag-chip" href={getEntryHref('systems', system.data.slug)}>{system.data.title}</a>)}
					</div>
				</div>
			)}
			{relatedSources.length > 0 && (
				<div class="info-panel">
					<h3>Source layer</h3>
					<ul class="detail-list">
						{
							relatedSources.map((source) => (
								<li>
									<a href={getEntryHref('sources', source.data.slug)}>{source.data.title}</a>
									{' · '}
									<span>{source.data.tier}</span>
								</li>
							))
						}
					</ul>
				</div>
			)}
		</aside>
	</section>

	<section class="section-split">
		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Topics</p>
					<h2>Foundational pages linked here</h2>
				</div>
			</div>
			<div class="stack">
				{
					relatedTopics.length > 0 ? (
						sortByTitle(relatedTopics).map((topic) => (
							<ContentCard
								eyebrow={topic.data.maturity}
								title={topic.data.title}
								description={topic.data.summary}
								href={getEntryHref('topics', topic.data.slug)}
								meta={`Reviewed ${formatDate(topic.data.lastReviewed)}`}
							/>
						))
					) : (
						<div class="search-empty">Topic links for this procedure will appear here as the graph expands.</div>
					)
				}
			</div>
		</div>

		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Investigations</p>
					<h2>Diagnostic pages linked here</h2>
				</div>
			</div>
			<div class="stack">
				{
					relatedInvestigations.length > 0 ? (
						sortByTitle(relatedInvestigations).map((investigation) => (
							<ContentCard
								eyebrow={investigation.data.maturity}
								title={investigation.data.title}
								description={investigation.data.summary}
								href={getEntryHref('investigations', investigation.data.slug)}
								meta={`${investigation.data.investigationType} · Reviewed ${formatDate(investigation.data.lastReviewed)}`}
							/>
						))
					) : (
						<div class="search-empty">Investigation links for this procedure are still being expanded.</div>
					)
				}
			</div>
		</div>
	</section>

	<section class="section-split">
		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Conditions</p>
					<h2>Condition pages linked here</h2>
				</div>
			</div>
			<div class="stack">
				{
					relatedConditions.length > 0 ? (
						sortByTitle(relatedConditions).map((condition) => (
							<ContentCard
								eyebrow={condition.data.maturity}
								title={condition.data.title}
								description={condition.data.summary}
								href={getEntryHref('conditions', condition.data.slug)}
								meta={`Reviewed ${formatDate(condition.data.lastReviewed)}`}
							/>
						))
					) : (
						<div class="search-empty">Condition links for this procedure are still being expanded.</div>
					)
				}
			</div>
		</div>

		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Presentations</p>
					<h2>Presentation pages linked here</h2>
				</div>
			</div>
			<div class="stack">
				{
					relatedPresentations.length > 0 ? (
						sortByTitle(relatedPresentations).map((presentation) => (
							<ContentCard
								eyebrow={presentation.data.maturity}
								title={presentation.data.title}
								description={presentation.data.summary}
								href={getEntryHref('presentations', presentation.data.slug)}
								meta={`Reviewed ${formatDate(presentation.data.lastReviewed)}`}
							/>
						))
					) : (
						<div class="search-empty">Presentation links for this procedure are still being expanded.</div>
					)
				}
			</div>
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">More Procedures</p>
				<h2>Related practical pages</h2>
			</div>
		</div>
		<div class="card-grid">
			{
				relatedProcedures.length > 0 ? (
					relatedProcedures.map((procedure) => (
						<ContentCard
							eyebrow={procedure.data.maturity}
							title={procedure.data.title}
							description={procedure.data.summary}
							href={getEntryHref('procedures', procedure.data.slug)}
							meta={`${procedure.data.procedureType} · Reviewed ${formatDate(procedure.data.lastReviewed)}`}
						/>
					))
				) : (
					<div class="search-empty">More connected procedure pages will appear here as the practical layer grows.</div>
				)
			}
		</div>
	</section>
</Layout>
