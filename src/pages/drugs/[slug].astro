---
import { getCollection, render } from 'astro:content';
import ContentCard from '../../components/ContentCard.astro';
import PageIntro from '../../components/PageIntro.astro';
import Layout from '../../layouts/Layout.astro';
import { formatDate, getEntryHref, resolveBySlugs, sortByTitle } from '../../lib/content';

export async function getStaticPaths() {
	const drugs = await getCollection('drugs');
	return drugs.map((entry) => ({
		params: { slug: entry.data.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const [systems, topics, conditions, presentations, sources, drugs] = await Promise.all([
	getCollection('systems'),
	getCollection('topics'),
	getCollection('conditions'),
	getCollection('presentations'),
	getCollection('sources'),
	getCollection('drugs'),
]);

const relatedSystems = resolveBySlugs(systems, entry.data.systems);
const relatedTopics = resolveBySlugs(topics, entry.data.relatedTopics);
const relatedConditions = resolveBySlugs(conditions, entry.data.relatedConditions);
const relatedPresentations = resolveBySlugs(presentations, entry.data.relatedPresentations);
const relatedSources = resolveBySlugs(sources, entry.data.sourceSlugs);
const relatedDrugs = sortByTitle(
	drugs.filter(
		(item) =>
			item.data.slug !== entry.data.slug &&
			(item.data.drugClass === entry.data.drugClass ||
				item.data.systems.some((slug) => entry.data.systems.includes(slug))),
	).slice(0, 4),
);
---

<Layout title={`${entry.data.title} | Med Wiki`} description={entry.data.summary} pagefindIndexed={true}>
	<PageIntro
		eyebrow="Drug"
		title={entry.data.title}
		summary={entry.data.summary}
		meta={[
			entry.data.drugClass,
			`${entry.data.maturity} page`,
			`Reviewed ${formatDate(entry.data.lastReviewed)}`,
		]}
		breadcrumbs={[
			{ label: 'Home', href: '/' },
			{ label: 'Drugs', href: '/drugs' },
			{ label: entry.data.title },
		]}
	/>

	<section class="page-grid">
		<article class="page-copy prose" data-pagefind-body>
			<section>
				<h2>Why this drug matters</h2>
				<p>{entry.data.whyItMatters}</p>
			</section>
			{entry.data.coreUses.length > 0 && (
				<section>
					<h2>Core uses</h2>
					<ul>
						{entry.data.coreUses.map((item) => <li>{item}</li>)}
					</ul>
				</section>
			)}
			{entry.data.majorCautions.length > 0 && (
				<section>
					<h2>Major cautions</h2>
					<ul>
						{entry.data.majorCautions.map((item) => <li>{item}</li>)}
					</ul>
				</section>
			)}
			{entry.data.commonAdverseEffects.length > 0 && (
				<section>
					<h2>Common adverse effects</h2>
					<ul>
						{entry.data.commonAdverseEffects.map((item) => <li>{item}</li>)}
					</ul>
				</section>
			)}
			<Content />
		</article>

		<aside class="page-sidebar">
			<div class="info-panel">
				<h3>Drug profile</h3>
				<ul class="detail-list">
					<li>Class: {entry.data.drugClass}</li>
					<li>Maturity: {entry.data.maturity}</li>
					<li>Last reviewed: {formatDate(entry.data.lastReviewed)}</li>
					<li>{entry.data.coreUses.length} core use{entry.data.coreUses.length === 1 ? '' : 's'}</li>
				</ul>
			</div>
			{entry.data.keyPoints.length > 0 && (
				<div class="info-panel">
					<h3>High-yield points</h3>
					<ul class="detail-list">
						{entry.data.keyPoints.map((item) => <li>{item}</li>)}
					</ul>
				</div>
			)}
			{relatedSystems.length > 0 && (
				<div class="info-panel">
					<h3>Linked systems</h3>
					<div class="link-list">
						{relatedSystems.map((system) => <a class="tag-chip" href={getEntryHref('systems', system.data.slug)}>{system.data.title}</a>)}
					</div>
				</div>
			)}
			{relatedSources.length > 0 && (
				<div class="info-panel">
					<h3>Source layer</h3>
					<ul class="detail-list">
						{
							relatedSources.map((source) => (
								<li>
									<a href={getEntryHref('sources', source.data.slug)}>{source.data.title}</a>
									{' · '}
									<span>{source.data.tier}</span>
								</li>
							))
						}
					</ul>
				</div>
			)}
		</aside>
	</section>

	<section class="section-split">
		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Topics</p>
					<h2>Foundational pages linked here</h2>
				</div>
			</div>
			<div class="stack">
				{
					relatedTopics.length > 0 ? (
						sortByTitle(relatedTopics).map((topic) => (
							<ContentCard
								eyebrow={topic.data.maturity}
								title={topic.data.title}
								description={topic.data.summary}
								href={getEntryHref('topics', topic.data.slug)}
								meta={`Reviewed ${formatDate(topic.data.lastReviewed)}`}
							/>
						))
					) : (
						<div class="search-empty">Topic links for this drug will appear here as the graph expands.</div>
					)
				}
			</div>
		</div>

		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Conditions</p>
					<h2>Condition pages linked here</h2>
				</div>
			</div>
			<div class="stack">
				{
					relatedConditions.length > 0 ? (
						sortByTitle(relatedConditions).map((condition) => (
							<ContentCard
								eyebrow={condition.data.maturity}
								title={condition.data.title}
								description={condition.data.summary}
								href={getEntryHref('conditions', condition.data.slug)}
								meta={`Reviewed ${formatDate(condition.data.lastReviewed)}`}
							/>
						))
					) : (
						<div class="search-empty">Condition links for this drug are still being expanded.</div>
					)
				}
			</div>
		</div>
	</section>

	<section class="section-split">
		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Presentations</p>
					<h2>Presentation pages linked here</h2>
				</div>
			</div>
			<div class="stack">
				{
					relatedPresentations.length > 0 ? (
						sortByTitle(relatedPresentations).map((presentation) => (
							<ContentCard
								eyebrow={presentation.data.maturity}
								title={presentation.data.title}
								description={presentation.data.summary}
								href={getEntryHref('presentations', presentation.data.slug)}
								meta={`Reviewed ${formatDate(presentation.data.lastReviewed)}`}
							/>
						))
					) : (
						<div class="search-empty">Presentation links for this drug are still being expanded.</div>
					)
				}
			</div>
		</div>

		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">More Drugs</p>
					<h2>Related formulary pages</h2>
				</div>
			</div>
			<div class="stack">
				{
					relatedDrugs.length > 0 ? (
						relatedDrugs.map((drug) => (
							<ContentCard
								eyebrow={drug.data.maturity}
								title={drug.data.title}
								description={drug.data.summary}
								href={getEntryHref('drugs', drug.data.slug)}
								meta={`${drug.data.drugClass} · Reviewed ${formatDate(drug.data.lastReviewed)}`}
							/>
						))
					) : (
						<div class="search-empty">More connected drug pages will appear here as the formulary grows.</div>
					)
				}
			</div>
		</div>
	</section>
</Layout>
