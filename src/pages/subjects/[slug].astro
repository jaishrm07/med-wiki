---
import { getCollection, render } from 'astro:content';
import ContentCard from '../../components/ContentCard.astro';
import PageIntro from '../../components/PageIntro.astro';
import Layout from '../../layouts/Layout.astro';
import { formatDate, getEntryHref, resolveBySlugs, sortByTitle, uniqueBySlug } from '../../lib/content';

export async function getStaticPaths() {
	const subjects = await getCollection('subjects');
	return subjects.map((entry) => ({
		params: { slug: entry.data.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const [phases, systems, topics, conditions, procedures] = await Promise.all([
	getCollection('phases'),
	getCollection('systems'),
	getCollection('topics'),
	getCollection('conditions'),
	getCollection('procedures'),
]);

const relatedPhase = phases.find((item) => item.data.slug === entry.data.phase);
const relatedSystems = resolveBySlugs(systems, entry.data.systems);
const relatedTopics = sortByTitle(
	uniqueBySlug([
		...resolveBySlugs(topics, entry.data.topicSlugs),
		...topics.filter((item) => item.data.subject === entry.data.slug),
	]),
);
const relatedConditions = sortByTitle(
	conditions.filter((item) => item.data.primarySubject === entry.data.slug || item.data.relatedTopics.some((slug) => relatedTopics.some((topic) => topic.data.slug === slug))),
);
const relatedProcedures = sortByTitle(
	procedures.filter(
		(item) =>
			item.data.primarySubject === entry.data.slug ||
			item.data.relatedTopics.some((slug) => relatedTopics.some((topic) => topic.data.slug === slug)),
	),
);
---

<Layout title={`${entry.data.title} | Med Wiki`} description={entry.data.summary} pagefindIndexed={true}>
	<PageIntro
		eyebrow="Subject"
		title={entry.data.title}
		summary={entry.data.summary}
		meta={[relatedPhase?.data.title ?? 'MBBS', entry.data.whyItMatters]}
		breadcrumbs={[
			{ label: 'Home', href: '/' },
			{ label: 'Subjects', href: '/subjects' },
			{ label: entry.data.title },
		]}
	/>

	<section class="page-grid">
		<article class="page-copy prose" data-pagefind-body>
			<section>
				<h2>Why this subject matters</h2>
				<p>{entry.data.whyItMatters}</p>
			</section>
			<section>
				<h2>Core blocks</h2>
				<div class="link-list">
					{entry.data.coreBlocks.map((item) => <span class="tag-chip">{item}</span>)}
				</div>
			</section>
			{entry.data.skills.length > 0 && (
				<section>
					<h2>Skills students should build</h2>
					<div class="link-list">
						{entry.data.skills.map((item) => <span class="tag-chip">{item}</span>)}
					</div>
				</section>
			)}
			<Content />
		</article>

		<aside class="page-sidebar">
			<div class="info-panel">
				<h3>At a glance</h3>
				<ul class="detail-list">
					<li>{relatedPhase?.data.title ?? 'MBBS course layer'}</li>
					<li>{relatedSystems.length} linked system{relatedSystems.length === 1 ? '' : 's'}</li>
					<li>{relatedTopics.length} topic page{relatedTopics.length === 1 ? '' : 's'}</li>
					<li>{relatedConditions.length} condition page{relatedConditions.length === 1 ? '' : 's'}</li>
					<li>{relatedProcedures.length} procedure page{relatedProcedures.length === 1 ? '' : 's'}</li>
				</ul>
			</div>
			{relatedSystems.length > 0 && (
				<div class="info-panel">
					<h3>Linked systems</h3>
					<div class="link-list">
						{relatedSystems.map((system) => <a class="tag-chip" href={getEntryHref('systems', system.data.slug)}>{system.data.title}</a>)}
					</div>
				</div>
			)}
		</aside>
	</section>

	<section class="section-split">
		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Systems</p>
					<h2>Where this subject connects outward</h2>
				</div>
			</div>
			<div class="stack">
				{
					relatedSystems.length > 0 ? (
						relatedSystems.map((system) => (
							<ContentCard
								eyebrow="System"
								title={system.data.title}
								description={system.data.summary}
								href={getEntryHref('systems', system.data.slug)}
							/>
						))
					) : (
						<div class="search-empty">This subject already exists in the map, but its system pages are still being filled in.</div>
					)
				}
			</div>
		</div>

		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Topics</p>
					<h2>Current study pages in this subject</h2>
				</div>
			</div>
			<div class="stack">
				{
					relatedTopics.length > 0 ? (
						relatedTopics.map((topic) => (
							<ContentCard
								eyebrow="Topic"
								title={topic.data.title}
								description={topic.data.summary}
								href={getEntryHref('topics', topic.data.slug)}
							/>
						))
					) : (
						<div class="search-empty">Topic coverage for this subject is part of the next content wave.</div>
					)
				}
			</div>
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Conditions</p>
				<h2>Clinical pages linked to this subject</h2>
			</div>
		</div>
		<div class="card-grid">
			{
				relatedConditions.length > 0 ? (
					relatedConditions.map((condition) => (
						<ContentCard
							eyebrow={condition.data.maturity}
							title={condition.data.title}
							description={condition.data.summary}
							href={getEntryHref('conditions', condition.data.slug)}
							meta={`Reviewed ${formatDate(condition.data.lastReviewed)}`}
						/>
					))
				) : (
					<div class="search-empty">Condition pages for this subject are part of the next clinical expansion pass.</div>
				)
			}
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Procedures</p>
				<h2>Practical pages linked to this subject</h2>
			</div>
		</div>
		<div class="card-grid">
			{
				relatedProcedures.length > 0 ? (
					relatedProcedures.map((procedure) => (
						<ContentCard
							eyebrow={procedure.data.maturity}
							title={procedure.data.title}
							description={procedure.data.summary}
							href={getEntryHref('procedures', procedure.data.slug)}
							meta={`${procedure.data.procedureType} · Reviewed ${formatDate(procedure.data.lastReviewed)}`}
						/>
					))
				) : (
					<div class="search-empty">Procedure coverage for this subject is part of the next practical-skills wave.</div>
				)
			}
		</div>
	</section>
</Layout>
