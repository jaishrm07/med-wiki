---
import { getCollection, render } from 'astro:content';
import ContentCard from '../../components/ContentCard.astro';
import DiagramPanel from '../../components/DiagramPanel.astro';
import PageIntro from '../../components/PageIntro.astro';
import Layout from '../../layouts/Layout.astro';
import { filterByRelationship, formatDate, getEntryHref, sortByTitle } from '../../lib/content';

export async function getStaticPaths() {
	const sources = await getCollection('sources');
	return sources.map((entry) => ({
		params: { slug: entry.data.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const [topics, conditions, presentations, diagrams, drugs, investigations, procedures] = await Promise.all([
	getCollection('topics'),
	getCollection('conditions'),
	getCollection('presentations'),
	getCollection('diagrams'),
	getCollection('drugs'),
	getCollection('investigations'),
	getCollection('procedures'),
]);
const linkedTopics = sortByTitle(filterByRelationship(topics, 'sourceSlugs', entry.data.slug));
const linkedConditions = sortByTitle(filterByRelationship(conditions, 'sourceSlugs', entry.data.slug));
const linkedPresentations = sortByTitle(filterByRelationship(presentations, 'sourceSlugs', entry.data.slug));
const linkedDiagrams = sortByTitle(filterByRelationship(diagrams, 'sourceSlugs', entry.data.slug));
const linkedDrugs = sortByTitle(filterByRelationship(drugs, 'sourceSlugs', entry.data.slug));
const linkedInvestigations = sortByTitle(filterByRelationship(investigations, 'sourceSlugs', entry.data.slug));
const linkedProcedures = sortByTitle(filterByRelationship(procedures, 'sourceSlugs', entry.data.slug));
---

<Layout title={`${entry.data.title} | Med Wiki`} description={entry.data.description} pagefindIndexed={true}>
	<PageIntro
		eyebrow="Source"
		title={entry.data.title}
		summary={entry.data.description}
		meta={[
			entry.data.publisher,
			`${entry.data.sourceType} · ${entry.data.tier}`,
			`Reviewed ${formatDate(entry.data.lastReviewed)}`,
		]}
		breadcrumbs={[
			{ label: 'Home', href: '/' },
			{ label: 'Sources', href: '/sources' },
			{ label: entry.data.title },
		]}
	/>

	<section class="page-grid">
		<article class="page-copy prose" data-pagefind-body>
			<section>
				<h2>Why this source matters</h2>
				<p>{entry.data.description}</p>
			</section>
			<Content />
		</article>

		<aside class="page-sidebar">
			<div class="info-panel">
				<h3>Source profile</h3>
				<ul class="detail-list">
					<li>Publisher: {entry.data.publisher}</li>
					<li>Type: {entry.data.sourceType}</li>
					<li>Tier: {entry.data.tier}</li>
					<li>Last reviewed: {formatDate(entry.data.lastReviewed)}</li>
					{entry.data.edition && <li>Edition: {entry.data.edition}</li>}
				</ul>
			</div>
			{entry.data.recommendedFor.length > 0 && (
				<div class="info-panel">
					<h3>Recommended for</h3>
					<div class="link-list">
						{entry.data.recommendedFor.map((item) => <span class="tag-chip">{item}</span>)}
					</div>
				</div>
			)}
			{entry.data.url && (
				<div class="info-panel">
					<h3>External link</h3>
					<p><a class="section-link" href={entry.data.url} target="_blank" rel="noreferrer">Open source page</a></p>
				</div>
			)}
		</aside>
	</section>

	<section class="section-split">
		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Linked Topics</p>
					<h2>Foundational pages using this source</h2>
				</div>
			</div>
			<div class="stack">
				{
					linkedTopics.length > 0 ? (
						linkedTopics.map((topic) => (
							<ContentCard
								eyebrow={topic.data.maturity}
								title={topic.data.title}
								description={topic.data.summary}
								href={getEntryHref('topics', topic.data.slug)}
								meta={`Reviewed ${formatDate(topic.data.lastReviewed)}`}
							/>
						))
					) : (
						<div class="search-empty">No topic pages are linked to this source yet.</div>
					)
				}
			</div>
		</div>

		<div class="section-panel">
			<div class="section-heading compact">
				<div>
					<p class="eyebrow">Linked Conditions</p>
					<h2>Clinical pages using this source</h2>
				</div>
			</div>
			<div class="stack">
				{
					linkedConditions.length > 0 ? (
						linkedConditions.map((condition) => (
							<ContentCard
								eyebrow={condition.data.maturity}
								title={condition.data.title}
								description={condition.data.summary}
								href={getEntryHref('conditions', condition.data.slug)}
								meta={`Reviewed ${formatDate(condition.data.lastReviewed)}`}
							/>
						))
					) : (
						<div class="search-empty">No condition pages are linked to this source yet.</div>
					)
				}
			</div>
		</div>
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Linked Presentations</p>
				<h2>Symptom-first pages using this source</h2>
			</div>
		</div>
		{
			linkedPresentations.length > 0 ? (
				<div class="card-grid">
					{
						linkedPresentations.map((presentation) => (
							<ContentCard
								eyebrow={presentation.data.maturity}
								title={presentation.data.title}
								description={presentation.data.summary}
								href={getEntryHref('presentations', presentation.data.slug)}
								meta={`Reviewed ${formatDate(presentation.data.lastReviewed)}`}
							/>
						))
					}
				</div>
			) : (
				<div class="search-empty">No presentation pages are linked to this source yet.</div>
			)
		}
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Linked Diagrams</p>
				<h2>Visual assets using this source</h2>
			</div>
		</div>
		{
			linkedDiagrams.length > 0 ? (
				<div class="diagram-grid">
					{linkedDiagrams.map((diagram) => <DiagramPanel diagram={diagram} mode="compact" />)}
				</div>
			) : (
				<div class="search-empty">No diagram pages are linked to this source yet.</div>
			)
		}
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Linked Drugs</p>
				<h2>Formulary pages using this source</h2>
			</div>
		</div>
		{
			linkedDrugs.length > 0 ? (
				<div class="card-grid">
					{
						linkedDrugs.map((drug) => (
							<ContentCard
								eyebrow={drug.data.maturity}
								title={drug.data.title}
								description={drug.data.summary}
								href={getEntryHref('drugs', drug.data.slug)}
								meta={`${drug.data.drugClass} · Reviewed ${formatDate(drug.data.lastReviewed)}`}
							/>
						))
					}
				</div>
			) : (
				<div class="search-empty">No drug pages are linked to this source yet.</div>
			)
		}
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Linked Investigations</p>
				<h2>Diagnostic pages using this source</h2>
			</div>
		</div>
		{
			linkedInvestigations.length > 0 ? (
				<div class="card-grid">
					{
						linkedInvestigations.map((investigation) => (
							<ContentCard
								eyebrow={investigation.data.maturity}
								title={investigation.data.title}
								description={investigation.data.summary}
								href={getEntryHref('investigations', investigation.data.slug)}
								meta={`${investigation.data.investigationType} · Reviewed ${formatDate(investigation.data.lastReviewed)}`}
							/>
						))
					}
				</div>
			) : (
				<div class="search-empty">No investigation pages are linked to this source yet.</div>
			)
		}
	</section>

	<section class="section-block">
		<div class="section-heading">
			<div>
				<p class="eyebrow">Linked Procedures</p>
				<h2>Practical pages using this source</h2>
			</div>
		</div>
		{
			linkedProcedures.length > 0 ? (
				<div class="card-grid">
					{
						linkedProcedures.map((procedure) => (
							<ContentCard
								eyebrow={procedure.data.maturity}
								title={procedure.data.title}
								description={procedure.data.summary}
								href={getEntryHref('procedures', procedure.data.slug)}
								meta={`${procedure.data.procedureType} · Reviewed ${formatDate(procedure.data.lastReviewed)}`}
							/>
						))
					}
				</div>
			) : (
				<div class="search-empty">No procedure pages are linked to this source yet.</div>
			)
		}
	</section>
</Layout>
